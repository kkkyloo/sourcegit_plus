  <x:String x:Key="Text.Configure.CustomAction.Arguments.Tip" xml:space="preserve">—Е–Х–Ј—ЕвХЧвХС—Е–Я–У—Ж–•вХХ:

  ${REPO} —Е–љ–®—Ж–§вХЫ—ЕвХС–ї—ИвХЦ–њ—ЕвХЫ–°
  ${REMOTE} —Ж–Щ–Р—Й–СвХХ—З–™–Ф—Й–С–∞—З–ї–њ—Е–љ–®—Ж–§вХЫ—ЕвХС–ї—Ж–Ш–¶—Ж–Щ–Р—Й–СвХХ—Е–Ш–Ц—Ж–§–њ—З–™–Ф—Й–С–∞—З–ї–њ
  ${BRANCH} —Ж–Щ–Р—Й–СвХХ—З–™–Ф—Е–Ш–Ц—Ж–§–њ—Г–Р–Т—ЕвЦС–Э—Ж–¶вХЭ—Й–С–∞—З–ї–њ—Е–Ш–Ц—Ж–§–њ—ПвХЭ–Ь—ДвХХ–Э—Е–Ь–Х—Е–†–ї—Й–С–∞—З–ї–њ—Е–†–Э—З–ЄвЦТ
  ${BRANCH_FRIENDLY_NAME} —Ж–Щ–Р—Й–СвХХ—З–™–Ф—Е–Ш–Ц—Ж–§–њ—Г–Р–Т—ЕвЦС–Э—Ж–¶вХЭ—Й–С–∞—З–ї–њ—Е–Ш–Ц—Ж–§–њ—ПвХЭ–Ь—ДвХХ–Э—Е–Ь–Х—Е–†–ї—Й–С–∞—З–ї–њ—Е–†–Э—З–ЄвЦТ
  ${SHA} —Ж–Щ–Р—Й–СвХХ—З–™–Ф—Ж–Я–†—ДвХС–і—ЗвХЦ–Є—И–©–ѓ
  ${TAG} —Ж–Щ–Р—Й–СвХХ—З–™–Ф—Ж–Є–©—ЗвЦТ–і
  ${FILE} —Ж–Щ–Р—Й–СвХХ—З–™–Ф—Ж–Ї–§—Ж–±–Ш—ПвХЭ–Ь—З–ЂвХХ—ЕвЦС–Э—Ж–¶вХЭ—Е–љ–®—Ж–§вХЫ—ЕвХС–ї—Ж–∞вХ£—З–Ђ–Њ—Й–Ь–Ф—З–™–Ф—ИвХЦ–њ—ЕвХЫ–°
  $1, $2 ... —ИвХЭвХХ—Е–Х–µ—Ж–Ю–Ј—Е–ШвХҐ—Й–∞–Х—ДвХХ–љ—З–™–Ф—Е–РвХЭ</x:String>
