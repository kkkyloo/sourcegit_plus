  <x:String x:Key="Text.Configure.OpenAI.Preferred" xml:space="preserve">в•ЁРҜв•ӨРҗв•Ёв•Ўв•Ёв”Өв•Ёв”җв•Ёв•ӣв•ӨР—в•ӨР’в•Ёв••в•ӨР’в•Ёв•Ўв•Ёв•—в•ӨРңв•Ёв•ңв•ӨРӣв•Ёв•Ј в•ӨР‘в•Ёв•Ўв•ӨРҗв•Ёв–“в•Ёв••в•ӨР‘:</x:String>
  <x:String x:Key="Text.Configure.OpenAI.Preferred.Tip" xml:space="preserve">в•ЁРҘв•ӨР‘в•Ёв•—в•Ёв•• в”¬Р»в•ЁРҜв•ӨРҗв•Ёв•Ўв•Ёв”Өв•Ёв”җв•Ёв•ӣв•ӨР—в•ӨР’в•Ёв••в•ӨР’в•Ёв•Ўв•Ёв•—в•ӨРңв•Ёв•ңв•ӨРӣв•Ёв•Ј в•ӨР‘в•Ёв•Ўв•ӨРҗв•Ёв–“в•Ёв••в•ӨР‘в”¬в•— в•ӨР“в•ӨР‘в•ӨР’в•Ёв–‘в•Ёв•ңв•Ёв•ӣв•Ёв–“в•Ёв•—в•Ёв•Ўв•Ёв•ң, SourceGit в•Ёв–’в•ӨР“в•Ёв”Өв•Ёв•Ўв•ӨР’ в•Ёв••в•ӨР‘в•Ёв”җв•Ёв•ӣв•Ёв•—в•ӨРңв•Ёв•–в•Ёв•ӣв•Ёв–“в•Ёв–‘в•ӨР’в•ӨРң в•ӨР’в•Ёв•ӣв•Ёв•—в•ӨРңв•Ёв•‘в•Ёв•ӣ в•ӨРқв•ӨР’в•Ёв•ӣв•ӨР’ в•ӨРҗв•Ёв•Ўв•Ёв”җв•Ёв•ӣв•Ёв•–в•Ёв••в•ӨР’в•Ёв•ӣв•ӨРҗв•Ёв••в•Ёв•Ј. в•ЁРў в•Ёв”җв•ӨРҗв•Ёв•ӣв•ӨР’в•Ёв••в•Ёв–“в•Ёв•ңв•Ёв•ӣв•Ёв•қ в•ӨР‘в•Ёв•—в•ӨР“в•ӨР—в•Ёв–‘в•Ёв•Ў, в•Ёв•Ўв•ӨР‘в•Ёв•—в•Ёв•• в•Ёв”Өв•Ёв•ӣв•ӨР‘в•ӨР’в•ӨР“в•Ёв”җв•Ёв•ңв•Ёв•ӣ в•Ёв–’в•Ёв•ӣв•Ёв•—в•Ёв•Ўв•Ёв•Ў в•Ёв•ӣв•Ёв”Өв•Ёв•ңв•Ёв•ӣв•Ёв•Ј в•ӨР“в•ӨР‘в•Ёв•—в•ӨР“в•Ёв”Ӯв•Ёв••, в•Ёв–’в•ӨР“в•Ёв”Өв•Ёв•Ўв•ӨР’ в•Ёв•ӣв•ӨР’в•Ёв•ӣв•Ёв–’в•ӨРҗв•Ёв–‘в•Ёв•ўв•Ёв•Ўв•Ёв•ңв•Ёв•ӣ в•Ёв•‘в•Ёв•ӣв•Ёв•ңв•ӨР’в•Ёв•Ўв•Ёв•‘в•ӨР‘в•ӨР’в•Ёв•ңв•Ёв•ӣв•Ёв•Ў в•Ёв•қв•Ёв•Ўв•Ёв•ңв•ӨРһ в•Ёв”Өв•Ёв•—в•ӨРҹ в•Ёв–“в•ӨРӣв•Ёв–’в•Ёв•ӣв•ӨРҗв•Ёв–‘ в•Ёв•ӣв•Ёв”Өв•Ёв•ңв•Ёв•ӣв•Ёв•Ј в•Ёв••в•Ёв•– в•Ёв•ңв•Ёв••в•ӨР•.</x:String>
