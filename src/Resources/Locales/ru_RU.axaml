  <x:String x:Key="Text.GitFlow.StartRelease" xml:space="preserve">в•ЁР§в•Ёв–‘в•Ёв”җв•ӨР“в•ӨР‘в•Ёв•‘ в•Ёв–“в•ӨРӣв•Ёв”җв•ӨР“в•ӨР‘в•Ёв•‘в•Ёв–‘...</x:String>
  <x:String x:Key="Text.GitFlow.StartReleaseTitle" xml:space="preserve">в•ЁРҜв•ЁР°в•ЁР®в•ЁР¶в•ЁРҘв•ЁРұв•ЁРұ - в•ЁР§в•Ёв–‘в•Ёв”җв•ӨР“в•ӨР‘в•Ёв•‘ в•Ёв–“в•ӨРӣв•Ёв”җв•ӨР“в•ӨР‘в•Ёв•‘в•Ёв–‘</x:String>
  <x:String x:Key="Text.GitFlow.TagPrefix" xml:space="preserve">в•ЁРҜв•ӨРҗв•Ёв•Ўв•ӨР”в•Ёв••в•Ёв•‘в•ӨР‘ в•Ёв•қв•Ёв•Ўв•ӨР’в•Ёв•‘в•Ёв•• в•Ёв–“в•Ёв•Ўв•ӨРҗв•ӨР‘в•Ёв••в•Ёв••:</x:String>
  <x:String x:Key="Text.GitLFS" xml:space="preserve">Git LFS (в•ӨР•в•ӨРҗв•Ёв–‘в•Ёв•ңв•Ёв••в•Ёв•—в•Ёв••в•ӨРҷв•Ёв•Ў в•Ёв–’в•Ёв•ӣв•Ёв•—в•ӨРңв•ӨРҳв•Ёв••в•ӨР• в•ӨР”в•Ёв–‘в•Ёв•Јв•Ёв•—в•Ёв•ӣв•Ёв–“)</x:String>
  <x:String x:Key="Text.GitLFS.AddTrackPattern" xml:space="preserve">в•ЁРӨв•Ёв•ӣв•Ёв–’в•Ёв–‘в•Ёв–“в•Ёв••в•ӨР’в•ӨРң в•ӨРҳв•Ёв–‘в•Ёв–’в•Ёв•—в•Ёв•ӣв•Ёв•ң в•Ёв•ӣв•ӨР’в•ӨР‘в•Ёв•—в•Ёв•Ўв•Ёв•ўв•Ёв••в•Ёв–“в•Ёв–‘в•Ёв•ңв•Ёв••в•ӨРҹ...</x:String>
  <x:String x:Key="Text.GitLFS.AddTrackPattern.IsFilename" xml:space="preserve">в•ЁРёв•Ёв–‘в•Ёв–’в•Ёв•—в•Ёв•ӣв•Ёв•ң СӮРҗРӨ в•ӨРқв•ӨР’в•Ёв•ӣ в•Ёв••в•Ёв•қв•ӨРҹ в•ӨР”в•Ёв–‘в•Ёв•Јв•Ёв•—в•Ёв–‘</x:String>
  <x:String x:Key="Text.GitLFS.AddTrackPattern.Pattern" xml:space="preserve">в•ЁРЁв•Ёв•–в•Ёв•қв•Ёв•Ўв•Ёв•ңв•Ёв••в•ӨР’в•ӨРң в•ӨРҳв•Ёв–‘в•Ёв–’в•Ёв•—в•Ёв•ӣв•Ёв•ң:</x:String>
  <x:String x:Key="Text.GitLFS.AddTrackPattern.Title" xml:space="preserve">в•ЁРӨв•Ёв•ӣв•Ёв–’в•Ёв–‘в•Ёв–“в•Ёв••в•ӨР’в•ӨРң в•ӨРҳв•Ёв–‘в•Ёв–’в•Ёв•—в•Ёв•ӣв•Ёв•ң в•Ёв•ӣв•ӨР’в•ӨР‘в•Ёв•—в•Ёв•Ўв•Ёв•ўв•Ёв••в•Ёв–“в•Ёв–‘в•Ёв•ңв•Ёв••в•ӨРҹ в•Ёв–“ LFS Git</x:String>
  <x:String x:Key="Text.GitLFS.Fetch" xml:space="preserve">в•ЁРЁв•Ёв•–в•Ёв–“в•Ёв•—в•Ёв•Ўв•ӨР—в•ӨРң</x:String>
  <x:String x:Key="Text.GitLFS.Fetch.Tips" xml:space="preserve">в•ЁР§в•Ёв–‘в•Ёв”җв•ӨР“в•ӨР‘в•ӨР’в•Ёв••в•ӨР’в•ӨРң (git lfs fetch), в•ӨР—в•ӨР’в•Ёв•ӣв•Ёв–’в•ӨРӣ в•Ёв•–в•Ёв–‘в•Ёв”Ӯв•ӨРҗв•ӨР“в•Ёв•–в•Ёв••в•ӨР’в•ӨРң в•Ёв•ӣв•Ёв–’в•ӨРҡв•Ёв•Ўв•Ёв•‘в•ӨР’в•ӨРӣ LFS Git. в•ЁРҜв•ӨРҗв•Ёв•• в•ӨРқв•ӨР’в•Ёв•ӣв•Ёв•қ в•ӨРҗв•Ёв–‘в•Ёв–’в•Ёв•ӣв•ӨР—в•Ёв–‘в•ӨРҹ в•Ёв•‘в•Ёв•ӣв•Ёв”җв•Ёв••в•ӨРҹ в•Ёв•ңв•Ёв•Ў в•Ёв•ӣв•Ёв–’в•Ёв•ңв•Ёв•ӣв•Ёв–“в•Ёв•—в•ӨРҹв•Ёв•Ўв•ӨР’в•ӨР‘в•ӨРҹ.</x:String>
  <x:String x:Key="Text.GitLFS.Fetch.Title" xml:space="preserve">в•ЁРЁв•Ёв•–в•Ёв–“в•Ёв•—в•Ёв•Ўв•ӨР—в•ӨРң в•Ёв•ӣв•Ёв–’в•ӨРҡв•Ёв•Ўв•Ёв•‘в•ӨР’в•ӨРӣ LFS</x:String>
  <x:String x:Key="Text.GitLFS.Install" xml:space="preserve">в•ЁРів•ӨР‘в•ӨР’в•Ёв–‘в•Ёв•ңв•Ёв•ӣв•Ёв–“в•Ёв••в•ӨР’в•ӨРң в•Ёв”җв•Ёв•Ўв•ӨРҗв•Ёв•Ўв•ӨР•в•Ёв–“в•Ёв–‘в•ӨР’ LFS Git</x:String>
  <x:String x:Key="Text.GitLFS.Locks" xml:space="preserve">в•ЁРҜв•Ёв•ӣв•Ёв•‘в•Ёв–‘в•Ёв•–в•ӨРӣв•Ёв–“в•Ёв–‘в•ӨР’в•ӨРң в•Ёв–’в•Ёв•—в•Ёв•ӣв•Ёв•‘в•Ёв••в•ӨРҗв•Ёв•ӣв•Ёв–“в•Ёв•‘в•Ёв••</x:String>
  <x:String x:Key="Text.GitLFS.Locks.Empty" xml:space="preserve">в•ЁРӯв•Ёв•Ўв•ӨР’ в•Ёв•–в•Ёв–‘в•Ёв–’в•Ёв•—в•Ёв•ӣв•Ёв•‘в•Ёв••в•ӨРҗв•Ёв•ӣв•Ёв–“в•Ёв–‘в•Ёв•ңв•Ёв•ңв•ӨРӣв•ӨР• в•ӨР”в•Ёв–‘в•Ёв•Јв•Ёв•—в•Ёв•ӣв•Ёв–“</x:String>
  <x:String x:Key="Text.GitLFS.Locks.Lock" xml:space="preserve">в•ЁРЎв•Ёв•—в•Ёв•ӣв•Ёв•‘в•Ёв••в•ӨРҗв•Ёв•ӣв•Ёв–“в•Ёв•‘в•Ёв–‘</x:String>
  <x:String x:Key="Text.GitLFS.Locks.OnlyMine" xml:space="preserve">в•ЁРҜв•Ёв•ӣв•Ёв•‘в•Ёв–‘в•Ёв•–в•ӨРӣв•Ёв–“в•Ёв–‘в•ӨР’в•ӨРң в•ӨР’в•Ёв•ӣв•Ёв•—в•ӨРңв•Ёв•‘в•Ёв•ӣ в•Ёв•қв•Ёв•ӣв•Ёв•• в•Ёв–’в•Ёв•—в•Ёв•ӣв•Ёв•‘в•Ёв••в•ӨРҗв•Ёв•ӣв•Ёв–“в•Ёв•‘в•Ёв••</x:String>
  <x:String x:Key="Text.GitLFS.Locks.Title" xml:space="preserve">в•ЁРЎв•Ёв•—в•Ёв•ӣв•Ёв•‘в•Ёв••в•ӨРҗв•Ёв•ӣв•Ёв–“в•Ёв•‘в•Ёв•• LFS</x:String>
  <x:String x:Key="Text.GitLFS.Locks.Unlock" xml:space="preserve">в•ЁР°в•Ёв–‘в•Ёв•–в•Ёв–’в•Ёв•—в•Ёв•ӣв•Ёв•‘в•Ёв••в•ӨРҗв•Ёв•ӣв•Ёв–“в•Ёв–‘в•ӨР’в•ӨРң</x:String>
  <x:String x:Key="Text.GitLFS.Locks.UnlockAllMyLocks" xml:space="preserve">в•ЁРұв•Ёв•ңв•ӨРҹв•ӨР’в•ӨРң в•Ёв–“в•ӨР‘в•Ёв•Ў в•Ёв•қв•Ёв•ӣв•Ёв•• в•Ёв–’в•Ёв•—в•Ёв•ӣв•Ёв•‘в•Ёв••в•ӨРҗв•Ёв•ӣв•Ёв–“в•Ёв•‘в•Ёв••</x:String>
  <x:String x:Key="Text.GitLFS.Locks.UnlockAllMyLocks.Confirm" xml:space="preserve">в•ЁРўв•ӨРӣ в•ӨР“в•Ёв–“в•Ёв•Ўв•ӨРҗв•Ёв•Ўв•Ёв•ңв•ӨРӣ, в•ӨР—в•ӨР’в•Ёв•ӣ в•ӨР•в•Ёв•ӣв•ӨР’в•Ёв••в•ӨР’в•Ёв•Ў в•ӨР‘в•Ёв•ңв•ӨРҹв•ӨР’в•ӨРң в•Ёв–“в•ӨР‘в•Ёв•Ў в•ӨР‘в•Ёв–“в•Ёв•ӣв•Ёв•• в•Ёв–’в•Ёв•—в•Ёв•ӣв•Ёв•‘в•Ёв••в•ӨРҗв•Ёв•ӣв•Ёв–“в•Ёв•‘в•Ёв••?</x:String>
  <x:String x:Key="Text.GitLFS.Locks.UnlockForce" xml:space="preserve">в•ЁРҜв•ӨРҗв•Ёв••в•Ёв•ңв•ӨР“в•Ёв”Өв•Ёв••в•ӨР’в•Ёв•Ўв•Ёв•—в•ӨРңв•Ёв•ңв•Ёв•ӣ в•ӨРҗв•Ёв–‘в•Ёв•–в•Ёв–’в•Ёв•—в•Ёв•ӣв•Ёв•‘в•Ёв••в•ӨРҗв•Ёв•ӣв•Ёв–“в•Ёв–‘в•ӨР’в•ӨРң</x:String>
  <x:String x:Key="Text.GitLFS.Prune" xml:space="preserve">в•ЁР®в•Ёв–’в•ӨРҗв•Ёв•Ўв•Ёв•–в•Ёв–‘в•ӨР’в•ӨРң</x:String>
  <x:String x:Key="Text.GitLFS.Prune.Tips" xml:space="preserve">в•ЁР§в•Ёв–‘в•Ёв”җв•ӨР“в•ӨР‘в•ӨР’в•Ёв••в•ӨР’в•ӨРң (git lfs prune), в•ӨР—в•ӨР’в•Ёв•ӣв•Ёв–’в•ӨРӣ в•ӨР“в•Ёв”Өв•Ёв–‘в•Ёв•—в•Ёв••в•ӨР’в•ӨРң в•ӨР‘в•ӨР’в•Ёв–‘в•ӨРҗв•ӨРӣв•Ёв•Ў в•ӨР”в•Ёв–‘в•Ёв•Јв•Ёв•—в•ӨРӣ LFS в•Ёв••в•Ёв•– в•Ёв•—в•Ёв•ӣв•Ёв•‘в•Ёв–‘в•Ёв•—в•ӨРңв•Ёв•ңв•Ёв•ӣв•Ёв”Ӯв•Ёв•ӣ в•ӨР•в•ӨРҗв•Ёв–‘в•Ёв•ңв•Ёв••в•Ёв•—в•Ёв••в•ӨРҷв•Ёв–‘</x:String>
  <x:String x:Key="Text.GitLFS.Pull" xml:space="preserve">в•ЁР§в•Ёв–‘в•Ёв”Ӯв•ӨРҗв•ӨР“в•Ёв•–в•Ёв••в•ӨР’в•ӨРң</x:String>
  <x:String x:Key="Text.GitLFS.Pull.Tips" xml:space="preserve">в•ЁР§в•Ёв–‘в•Ёв”җв•ӨР“в•ӨР‘в•ӨР’в•Ёв••в•ӨР’в•ӨРң (git lfs pull), в•ӨР—в•ӨР’в•Ёв•ӣв•Ёв–’в•ӨРӣ в•Ёв•–в•Ёв–‘в•Ёв”Ӯв•ӨРҗв•ӨР“в•Ёв•–в•Ёв••в•ӨР’в•ӨРң в•Ёв–“в•ӨР‘в•Ёв•Ў в•ӨР”в•Ёв–‘в•Ёв•Јв•Ёв•—в•ӨРӣ LFS Git в•Ёв”Өв•Ёв•—в•ӨРҹ в•ӨР’в•Ёв•Ўв•Ёв•‘в•ӨР“в•ӨРҷв•Ёв•Ўв•Ёв•Ј в•ӨР‘в•ӨР‘в•ӨРӣв•Ёв•—в•Ёв•‘в•Ёв•• в•Ёв•• в•Ёв”җв•ӨРҗв•Ёв•ӣв•Ёв–“в•Ёв•Ўв•ӨРҗв•Ёв••в•ӨР’в•ӨРң</x:String>
