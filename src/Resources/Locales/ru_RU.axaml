  <x:String x:Key="Text.Configure.Git.AskBeforeAutoUpdatingSubmodules" xml:space="preserve">в•ЁРұв•Ёв”җв•ӨРҗв•Ёв–‘в•ӨРҳв•Ёв••в•Ёв–“в•Ёв–‘в•ӨР’в•ӨРң в•Ёв”җв•Ёв•Ўв•ӨРҗв•Ёв•Ўв•Ёв”Ө в•Ёв–‘в•Ёв–“в•ӨР’в•Ёв•ӣв•Ёв•қв•Ёв–‘в•ӨР’в•Ёв••в•ӨР—в•Ёв•Ўв•ӨР‘в•Ёв•‘в•Ёв••в•Ёв•қ в•Ёв•ӣв•Ёв–’в•Ёв•ңв•Ёв•ӣв•Ёв–“в•Ёв•—в•Ёв•Ўв•Ёв•ңв•Ёв••в•Ёв•Ўв•Ёв•қ в•Ёв”җв•Ёв•ӣв•Ёв”Өв•Ёв•қв•Ёв•ӣв•Ёв”Өв•ӨР“в•Ёв•—в•Ёв•Ўв•Ёв•Ј.</x:String>
